  (DESCRIPTION =
    (ADDRESS_LIST =
      (ADDRESS = (PROTOCOL = TCP)(HOST = 192.168.19.112)(PORT = 1521))
    )
    (CONNECT_DATA =
      (SERVICE_NAME = CIT1)
    )
  )

